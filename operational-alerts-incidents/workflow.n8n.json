        "options": {
          "responseCode": 200
        }
      },
      "id": "34fd9511-de9d-4272-abff-a6dcf70e3deb",
      "name": "Respond - Incident Registered",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        440,
